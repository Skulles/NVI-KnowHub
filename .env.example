# Скопируйте в .env.local (разработка) или задайте в CI для production-сборки.
# Префикс VITE_ обязателен — переменные попадают в клиентский bundle.

VITE_GITHUB_OWNER=your-org-or-user
VITE_GITHUB_REPO=your-repo-name
VITE_RELEASE_ASSET_NAME=knowhub-snapshot.sqlite
# Необязательно: по умолчанию будет <VITE_RELEASE_ASSET_NAME>.manifest.json
# VITE_RELEASE_MANIFEST_ASSET_NAME=knowhub-snapshot.sqlite.manifest.json
